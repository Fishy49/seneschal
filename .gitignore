# See https://help.github.com/articles/ignoring-files for more about ignoring files.
#
# Temporary files generated by your text editor or operating system
# belong in git's global ignore instead:
# `$XDG_CONFIG_HOME/git/ignore` or `~/.config/git/ignore`

# Ignore bundler config.
/.bundle

# Ignore all environment files.
/.env*

# Ignore all logfiles and tempfiles.
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

# Ignore pidfiles, but keep the directory.
/tmp/pids/*
!/tmp/pids/
!/tmp/pids/.keep

# Ignore storage (uploaded files in development and any SQLite databases).
/storage/*
!/storage/.keep
/tmp/storage/*
!/tmp/storage/
!/tmp/storage/.keep

/public/assets

# Ignore cloned repos, but keep the directory.
/repos/*
!/repos/.keep

# Filesystem-backed shared Skills are local user content. docker-compose
# bind-mounts `./skills` into the container so host scaffolds land here.
/skills/*
!/skills/.keep

# Per-run git worktrees. docker-compose optionally bind-mounts this dir.
/worktrees/*
!/worktrees/.keep

# Ignore key files for decrypting credentials and more.
/config/*.key


/app/assets/builds/*
!/app/assets/builds/.keep
.DS_Store

# Claude Code local cache + agent worktrees
.claude/
