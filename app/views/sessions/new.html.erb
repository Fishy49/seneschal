<h2 class="text-xl font-semibold text-center mb-6">Sign In</h2>

<%= form_with url: login_path, class: "space-y-4" do |f| %>
  <div>
    <label for="email" class="block text-sm font-medium text-content-muted mb-1.5">Email</label>
    <input type="email" name="email" id="email" autofocus required
           class="w-full px-3 py-2 bg-surface-input border border-edge rounded-lg text-content text-sm focus:outline-none focus:border-accent" />
  </div>

  <div>
    <label for="password" class="block text-sm font-medium text-content-muted mb-1.5">Password</label>
    <input type="password" name="password" id="password" required
           class="w-full px-3 py-2 bg-surface-input border border-edge rounded-lg text-content text-sm focus:outline-none focus:border-accent" />
  </div>

  <button type="submit"
          class="w-full px-4 py-2.5 bg-accent text-white rounded-lg text-sm font-semibold cursor-pointer hover:bg-accent-hover transition-colors">
    Sign In
  </button>
<% end %>

<p class="text-center text-sm text-content-muted mt-6">
  Don't have an account? <%= link_to "Register", register_path, class: "text-accent hover:text-accent-hover font-medium" %>
</p>
