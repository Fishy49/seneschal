<%= form_with model: skill do |f| %>
  <% if skill.errors.any? %>
    <div class="bg-danger/15 text-danger border border-danger/25 px-4 py-3 rounded-lg mb-4 text-sm">
      <% skill.errors.full_messages.each do |msg| %>
        <p><%= msg %></p>
      <% end %>
    </div>
  <% end %>

  <div class="mb-4">
    <%= f.label :name, class: "block text-sm font-medium text-content-muted mb-1.5" %>
    <%= f.text_field :name, placeholder: "ingest_feature",
          class: "w-full px-3 py-2 bg-surface-input border border-edge rounded-lg text-content text-sm focus:outline-none focus:border-accent" %>
  </div>

  <% scope_options = [["Shared (available to all projects)", ""]] +
       ProjectGroup.ordered.map { |g| ["Group: #{g.name}", "group:#{g.id}"] } +
       Project.order(:name).map { |p| ["Project: #{p.name}", "project:#{p.id}"] } %>
  <div class="mb-4">
    <%= f.label :scope, "Scope", class: "block text-sm font-medium text-content-muted mb-1.5" %>
    <%= f.select :scope, options_for_select(scope_options, skill.scope_value),
          {},
          class: "w-full px-3 py-2 bg-surface-input border border-edge rounded-lg text-content text-sm focus:outline-none focus:border-accent" %>
  </div>

  <div class="mb-4">
    <%= f.label :description, class: "block text-sm font-medium text-content-muted mb-1.5" %>
    <%= f.text_area :description, rows: 2, placeholder: "What this skill instructs Claude to do",
          class: "w-full px-3 py-2 bg-surface-input border border-edge rounded-lg text-content text-sm focus:outline-none focus:border-accent resize-y" %>
  </div>

  <div class="mb-4" data-controller="code-editor">
    <%= f.label :body, "Prompt", class: "block text-sm font-medium text-content-muted mb-1.5" %>
    <div class="codejar-wrap">
      <code class="language-markdown codejar-editor" data-code-editor-target="editor"></code>
    </div>
    <%= f.hidden_field :body, data: { code_editor_target: "input" } %>
  </div>

  <div class="flex gap-2">
    <%= f.submit class: "inline-flex items-center gap-1.5 px-4 py-2 bg-accent text-white rounded-lg text-sm font-medium cursor-pointer hover:bg-accent-hover transition-colors" %>
    <%= link_to "Cancel", skills_path, class: "inline-flex items-center gap-1.5 px-4 py-2 bg-transparent border border-edge text-content-muted rounded-lg text-sm font-medium hover:bg-surface-input hover:text-content transition-colors" %>
  </div>
<% end %>
