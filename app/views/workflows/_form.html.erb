<%= form_with model: [@project, workflow] do |f| %>
  <% if workflow.errors.any? %>
    <div class="bg-danger/15 text-danger border border-danger/25 px-4 py-3 rounded-lg mb-4 text-sm">
      <% workflow.errors.full_messages.each do |msg| %>
        <p><%= msg %></p>
      <% end %>
    </div>
  <% end %>

  <div class="mb-4">
    <%= f.label :name, class: "block text-sm font-medium text-content-muted mb-1.5" %>
    <%= f.text_field :name, placeholder: "classic_feature",
          class: "w-full px-3 py-2 bg-surface-input border border-edge rounded-lg text-content text-sm focus:outline-none focus:border-accent" %>
  </div>

  <div class="mb-4">
    <%= f.label :description, class: "block text-sm font-medium text-content-muted mb-1.5" %>
    <%= f.text_area :description, placeholder: "Build a classic mode feature from spec to PR",
          class: "w-full px-3 py-2 bg-surface-input border border-edge rounded-lg text-content text-sm focus:outline-none focus:border-accent resize-y min-h-20" %>
  </div>

  <div class="flex gap-2">
    <%= f.submit class: "inline-flex items-center gap-1.5 px-4 py-2 bg-accent text-white rounded-lg text-sm font-medium cursor-pointer hover:bg-accent-hover transition-colors" %>
    <%= link_to "Cancel", project_path(@project), class: "inline-flex items-center gap-1.5 px-4 py-2 bg-transparent border border-edge text-content-muted rounded-lg text-sm font-medium hover:bg-surface-input hover:text-content transition-colors" %>
  </div>
<% end %>
