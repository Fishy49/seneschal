<%= render "shared/project_bar", project: @project, workflow: @workflow %>

<div class="flex items-center justify-between mb-4">
  <h1 class="text-2xl font-semibold"><%= @workflow.name %></h1>
  <div class="flex items-center gap-2">
    <%= link_to "Edit", edit_project_workflow_path(@project, @workflow), class: "inline-flex items-center gap-1.5 px-2.5 py-1 bg-transparent border border-edge text-content-muted rounded-lg text-[0.8125rem] font-medium cursor-pointer hover:bg-surface-input hover:text-content transition-colors" %>
  </div>
</div>

<% if @workflow.description.present? %>
  <p class="text-content-muted mb-4"><%= @workflow.description %></p>
<% end %>

<div class="grid grid-cols-2 gap-4">
  <div>
    <div class="bg-surface-card border border-edge rounded-lg p-5 mb-4">
      <div class="flex items-center justify-between mb-3">
        <h2 class="text-lg font-semibold mb-0">Steps</h2>
        <%= link_to "Add Step", new_project_workflow_step_path(@project, @workflow), class: "inline-flex items-center gap-1.5 px-2.5 py-1 bg-transparent border border-edge text-content-muted rounded-lg text-[0.8125rem] font-medium cursor-pointer hover:bg-surface-input hover:text-content transition-colors" %>
      </div>
      <% if @steps.any? %>
        <ul class="list-none" data-controller="sortable-steps"
            data-sortable-steps-url-value="<%= reorder_project_workflow_steps_path(@project, @workflow) %>">
          <% @steps.each do |step| %>
            <li class="flex items-center gap-3 py-3 border-b border-edge last:border-b-0"
                draggable="true" data-step-id="<%= step.id %>"
                data-sortable-steps-target="item"
                data-action="dragstart->sortable-steps#dragstart dragend->sortable-steps#dragend dragover->sortable-steps#dragover dragleave->sortable-steps#dragleave drop->sortable-steps#drop"
                style="cursor: grab;">
              <span data-position-badge class="w-7 h-7 rounded-full bg-surface-input text-content-muted text-[0.8125rem] font-semibold flex items-center justify-center shrink-0"><%= step.position %></span>
              <div class="flex-1">
                <% if step.consumes.any? %>
                  <div class="flex flex-wrap gap-1 mb-1">
                    <% step.consumes.each do |var| %>
                      <span class="inline-block px-1.5 py-0 rounded text-[0.625rem] bg-info/15 text-info font-mono">&larr; <%= var %></span>
                    <% end %>
                  </div>
                <% end %>
                <div class="font-medium"><%= step.name %></div>
                <div class="text-[0.8125rem] text-content-muted">
                  <%= type_badge(step.step_type) %>
                  <% if step.max_retries > 0 %>
                    &middot; <%= step.max_retries %> retries
                  <% end %>
                  &middot; <%= step.timeout %>s timeout
                </div>
                <% ctx = Project.where(id: step.context_project_ids).order(:name) %>
                <% if ctx.any? %>
                  <div class="flex flex-wrap gap-1 mt-1">
                    <% ctx.each do |p| %>
                      <span class="inline-block px-1.5 py-0 rounded text-[0.625rem] bg-accent/15 text-accent font-mono">+ <%= p.name %></span>
                    <% end %>
                  </div>
                <% end %>
                <% if step.produces.any? %>
                  <div class="flex flex-wrap gap-1 mt-1">
                    <% step.produces.each do |var| %>
                      <span class="inline-block px-1.5 py-0 rounded text-[0.625rem] bg-success/15 text-success font-mono">&rarr; <%= var %></span>
                    <% end %>
                  </div>
                <% end %>
              </div>
              <div class="flex items-center gap-2">
                <%= link_to "Edit", edit_project_workflow_step_path(@project, @workflow, step), class: "inline-flex items-center gap-1.5 px-2.5 py-1 bg-transparent border border-edge text-content-muted rounded-lg text-[0.8125rem] font-medium cursor-pointer hover:bg-surface-input hover:text-content transition-colors" %>
                <%= button_to "Remove", project_workflow_step_path(@project, @workflow, step),
                      method: :delete,
                      class: "inline-flex items-center gap-1.5 px-2.5 py-1 bg-transparent border border-edge text-content-muted rounded-lg text-[0.8125rem] font-medium cursor-pointer hover:bg-surface-input hover:text-content transition-colors",
                      data: { turbo_confirm: "Remove step '#{step.name}'?" } %>
              </div>
            </li>
          <% end %>
        </ul>
      <% else %>
        <p class="text-center py-8 text-content-muted"><%= link_to "Add the first step", new_project_workflow_step_path(@project, @workflow) %></p>
      <% end %>
    </div>
  </div>

  <div>
    <div class="bg-surface-card border border-edge rounded-lg p-5 mb-4">
      <h2 class="text-lg font-semibold mb-3">Recent Runs</h2>
      <%= render "shared/runs_list", runs: @recent_runs %>
    </div>
  </div>
</div>
