<div class="flex items-center justify-between mb-4">
  <div>
    <h1 class="text-2xl font-semibold">Skill Repos</h1>
    <p class="text-sm text-content-muted mt-1">
      External git repositories that ship agentskills.io <code>SKILL.md</code> folders.
      Synced every 6 hours, or on demand.
    </p>
  </div>
  <%= link_to "Add Repo", new_skill_repo_path,
        class: "inline-flex items-center gap-1.5 px-4 py-2 bg-accent text-white rounded-lg text-sm font-medium cursor-pointer hover:bg-accent-hover transition-colors" %>
</div>

<% if @skill_repos.any? %>
  <div class="bg-surface-card border border-edge rounded-lg p-5 mb-4">
    <table class="w-full border-collapse">
      <thead>
        <tr>
          <th class="text-left px-3 py-2 border-b border-edge text-xs font-semibold uppercase tracking-wide text-content-muted">Name</th>
          <th class="text-left px-3 py-2 border-b border-edge text-xs font-semibold uppercase tracking-wide text-content-muted">Repo</th>
          <th class="text-left px-3 py-2 border-b border-edge text-xs font-semibold uppercase tracking-wide text-content-muted">Branch</th>
          <th class="text-left px-3 py-2 border-b border-edge text-xs font-semibold uppercase tracking-wide text-content-muted">Status</th>
          <th class="text-right px-3 py-2 border-b border-edge text-xs font-semibold uppercase tracking-wide text-content-muted">Skills</th>
          <th class="text-left px-3 py-2 border-b border-edge text-xs font-semibold uppercase tracking-wide text-content-muted">Last sync</th>
          <th class="text-right px-3 py-2 border-b border-edge text-xs font-semibold uppercase tracking-wide text-content-muted">Pri</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @skill_repos.each do |repo| %>
          <tr>
            <td class="px-3 py-2 border-b border-edge">
              <%= link_to repo.name, skill_repo_path(repo), class: "font-medium" %>
            </td>
            <td class="px-3 py-2 border-b border-edge text-sm text-content-muted">
              <code class="text-xs"><%= truncate(repo.repo_url, length: 50) %></code>
            </td>
            <td class="px-3 py-2 border-b border-edge text-sm text-content-muted"><%= repo.branch %></td>
            <td class="px-3 py-2 border-b border-edge text-sm">
              <% if repo.last_sync_error.present? %>
                <span class="inline-flex items-center gap-1 px-1.5 py-0.5 bg-danger/15 text-danger rounded text-xs font-medium">error</span>
              <% elsif !repo.enabled? %>
                <span class="inline-flex items-center gap-1 px-1.5 py-0.5 bg-surface-input text-content-muted rounded text-xs font-medium">disabled</span>
              <% elsif repo.last_synced_at.nil? %>
                <span class="inline-flex items-center gap-1 px-1.5 py-0.5 bg-surface-input text-content-muted rounded text-xs font-medium">never synced</span>
              <% else %>
                <span class="inline-flex items-center gap-1 px-1.5 py-0.5 bg-accent/15 text-accent rounded text-xs font-medium">enabled</span>
              <% end %>
            </td>
            <td class="px-3 py-2 border-b border-edge text-sm text-right tabular-nums"><%= @skill_counts[repo.id] || 0 %></td>
            <td class="px-3 py-2 border-b border-edge text-sm text-content-muted">
              <%= repo.last_synced_at ? "#{time_ago_in_words(repo.last_synced_at)} ago" : "—" %>
            </td>
            <td class="px-3 py-2 border-b border-edge text-sm text-right tabular-nums"><%= repo.priority %></td>
            <td class="px-3 py-2 border-b border-edge text-right">
              <%= button_to "Sync", sync_skill_repo_path(repo),
                    class: "inline-flex items-center gap-1.5 px-2.5 py-1 bg-transparent border border-edge text-content-muted rounded-lg text-xs font-medium cursor-pointer hover:bg-surface-input hover:text-content transition-colors" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <div class="bg-surface-card border border-edge rounded-lg p-12 text-center text-content-muted">
    <p>No skill repos registered.</p>
    <p class="mt-2">
      <%= link_to "Add your first one", new_skill_repo_path %>
      — point it at a git repo containing agentskills.io <code>SKILL.md</code> folders.
    </p>
  </div>
<% end %>
