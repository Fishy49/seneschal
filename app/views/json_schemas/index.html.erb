<div class="flex items-center justify-between mb-4">
  <h1 class="text-2xl font-semibold">JSON Schemas</h1>
  <%= link_to "New Schema", new_json_schema_path, class: "inline-flex items-center gap-1.5 px-4 py-2 bg-accent text-white rounded-lg text-sm font-medium cursor-pointer hover:bg-accent-hover transition-colors" %>
</div>

<% if @schemas.any? %>
  <div class="bg-surface-card border border-edge rounded-lg p-5 mb-4">
    <table class="w-full border-collapse">
      <thead>
        <tr>
          <th class="text-left px-3 py-2 border-b border-edge text-xs font-semibold uppercase tracking-wide text-content-muted">Name</th>
          <th class="text-left px-3 py-2 border-b border-edge text-xs font-semibold uppercase tracking-wide text-content-muted">Description</th>
          <th class="text-left px-3 py-2 border-b border-edge text-xs font-semibold uppercase tracking-wide text-content-muted">Used by</th>
        </tr>
      </thead>
      <tbody>
        <% @schemas.each do |schema| %>
          <% usage_count = Step.where("config LIKE ?", "%\"json_schema_id\":#{schema.id}%").count %>
          <tr>
            <td class="px-3 py-2 border-b border-edge"><%= link_to schema.name, json_schema_path(schema) %></td>
            <td class="px-3 py-2 border-b border-edge text-sm text-content-muted"><%= truncate(schema.description, length: 80) %></td>
            <td class="px-3 py-2 border-b border-edge text-sm text-content-muted"><%= pluralize(usage_count, "step") %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <div class="bg-surface-card border border-edge rounded-lg p-12 text-center text-content-muted">
    <p>No schemas yet.</p>
    <p class="mt-2"><%= link_to "Create your first schema", new_json_schema_path %></p>
  </div>
<% end %>
