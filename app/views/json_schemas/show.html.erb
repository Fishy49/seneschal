<div class="flex items-center justify-between mb-4">
  <div>
    <p class="text-sm text-content-muted">JSON Schema</p>
    <h1 class="text-2xl font-semibold"><%= @schema.name %></h1>
  </div>
  <div class="flex items-center gap-2">
    <%= link_to "Edit", edit_json_schema_path(@schema), class: "inline-flex items-center gap-1.5 px-2.5 py-1 bg-transparent border border-edge text-content-muted rounded-lg text-[0.8125rem] font-medium cursor-pointer hover:bg-surface-input hover:text-content transition-colors" %>
    <%= button_to "Delete", json_schema_path(@schema), method: :delete,
          class: "inline-flex items-center gap-1.5 px-2.5 py-1 bg-danger text-white rounded-lg text-[0.8125rem] font-medium cursor-pointer hover:bg-danger/80 transition-colors",
          data: { turbo_confirm: "Delete schema '#{@schema.name}'?" } %>
  </div>
</div>

<% if @schema.description.present? %>
  <p class="text-content-muted mb-4"><%= @schema.description %></p>
<% end %>

<div class="bg-surface-card border border-edge rounded-lg p-5 mb-4">
  <h2 class="text-lg font-semibold mb-3">Schema Body</h2>
  <pre class="overflow-x-auto"><code class="language-json"><%= @schema.parsed_body ? JSON.pretty_generate(@schema.parsed_body) : @schema.body %></code></pre>
</div>

<% referencing_steps = @schema.referencing_steps.includes(workflow: :project) %>
<% if referencing_steps.any? %>
  <div class="bg-surface-card border border-edge rounded-lg p-5 mb-4">
    <h2 class="text-lg font-semibold mb-3">Used in Steps</h2>
    <table class="w-full border-collapse">
      <thead>
        <tr>
          <th class="text-left px-3 py-2 border-b border-edge text-xs font-semibold uppercase tracking-wide text-content-muted">Step</th>
          <th class="text-left px-3 py-2 border-b border-edge text-xs font-semibold uppercase tracking-wide text-content-muted">Workflow</th>
          <th class="text-left px-3 py-2 border-b border-edge text-xs font-semibold uppercase tracking-wide text-content-muted">Project</th>
        </tr>
      </thead>
      <tbody>
        <% referencing_steps.each do |step| %>
          <tr>
            <td class="px-3 py-2 border-b border-edge"><%= step.name %></td>
            <td class="px-3 py-2 border-b border-edge"><%= link_to step.workflow.name, project_workflow_path(step.workflow.project, step.workflow) %></td>
            <td class="px-3 py-2 border-b border-edge text-content-muted"><%= step.workflow.project.name %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>
