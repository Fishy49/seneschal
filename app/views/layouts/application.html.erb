<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Seneschal" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= action_cable_meta_tag %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <link rel="stylesheet" id="hljs-theme" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.11.1/styles/github-dark.min.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.11.1/highlight.min.js"></script>
    <script>
      (function() {
        var t = localStorage.getItem("theme") || "dark";
        document.documentElement.setAttribute("data-theme", t);
        if (t === "light") {
          document.getElementById("hljs-theme").href =
            "https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.11.1/styles/github.min.css";
        }
      })();
    </script>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <div class="grid grid-cols-[220px_1fr] min-h-screen">
      <nav class="bg-surface-card border-r border-edge p-6 px-4 flex flex-col gap-2 sticky top-0 h-screen overflow-y-auto">
        <div class="flex items-center gap-2 text-xl font-bold text-content px-2 mb-4">
          <%= image_tag "logo.png", size: 28, class: "rounded-md" %>
          Seneschal
        </div>
        <%= link_to "Dashboard", root_path,
              class: "block px-3 py-2 rounded-lg text-sm transition-colors #{controller_name == 'dashboard' ? 'bg-surface-input text-content' : 'text-content-muted hover:bg-surface-input hover:text-content'}" %>
        <div data-controller="sidebar-toggle">
          <div class="flex items-center justify-between">
            <%= link_to "Projects", projects_path,
                  class: "flex-1 block px-3 py-2 rounded-lg text-sm transition-colors #{controller_name == 'projects' ? 'bg-surface-input text-content' : 'text-content-muted hover:bg-surface-input hover:text-content'}" %>
            <% if Project.exists? %>
              <button type="button" class="bg-transparent border-none text-content-muted cursor-pointer px-2 py-1 text-xs rounded-lg hover:text-content hover:bg-surface-input" data-action="sidebar-toggle#toggle" data-sidebar-toggle-target="btn">
                <span data-sidebar-toggle-target="icon">&#9656;</span>
              </button>
            <% end %>
          </div>
          <div class="pl-3" data-sidebar-toggle-target="list" style="display:none">
            <% ProjectGroup.ordered.includes(:projects).each do |group| %>
              <% next if group.projects.empty? %>
              <p class="px-3 py-1 text-[0.75rem] font-semibold text-content-muted uppercase tracking-wide mt-1"><%= group.name %></p>
              <% group.projects.order(:name).each do |project| %>
                <%= link_to project.name, project_path(project),
                      class: "block px-3 py-1 rounded-lg text-[0.8125rem] transition-colors #{(controller_name == 'projects' && params[:id].to_s == project.id.to_s) ? 'text-content' : 'text-content-muted opacity-80 hover:opacity-100 hover:text-content'}" %>
              <% end %>
            <% end %>
            <% ungrouped = Project.where(project_group_id: nil).order(:name) %>
            <% if ungrouped.any? %>
              <% if ProjectGroup.exists? %>
                <p class="px-3 py-1 text-[0.75rem] font-semibold text-content-muted uppercase tracking-wide mt-1">Ungrouped</p>
              <% end %>
              <% ungrouped.each do |project| %>
                <%= link_to project.name, project_path(project),
                      class: "block px-3 py-1 rounded-lg text-[0.8125rem] transition-colors #{(controller_name == 'projects' && params[:id].to_s == project.id.to_s) ? 'text-content' : 'text-content-muted opacity-80 hover:opacity-100 hover:text-content'}" %>
              <% end %>
            <% end %>
          </div>
        </div>
        <%= link_to "Groups", project_groups_path,
              class: "block px-3 py-2 rounded-lg text-sm transition-colors #{controller_name == 'project_groups' ? 'bg-surface-input text-content' : 'text-content-muted hover:bg-surface-input hover:text-content'}" %>
        <%= link_to "Tasks", pipeline_tasks_path,
              class: "block px-3 py-2 rounded-lg text-sm transition-colors #{controller_name == 'pipeline_tasks' ? 'bg-surface-input text-content' : 'text-content-muted hover:bg-surface-input hover:text-content'}" %>
        <%= link_to "Skills", skills_path,
              class: "block px-3 py-2 rounded-lg text-sm transition-colors #{controller_name == 'skills' ? 'bg-surface-input text-content' : 'text-content-muted hover:bg-surface-input hover:text-content'}" %>
        <%= link_to "Runs", runs_path,
              class: "block px-3 py-2 rounded-lg text-sm transition-colors #{controller_name == 'runs' ? 'bg-surface-input text-content' : 'text-content-muted hover:bg-surface-input hover:text-content'}" %>
        <%= link_to "Templates", step_templates_path,
              class: "block px-3 py-2 rounded-lg text-sm transition-colors #{controller_name == 'step_templates' ? 'bg-surface-input text-content' : 'text-content-muted hover:bg-surface-input hover:text-content'}" %>
        <% if current_user&.admin? %>
          <%= link_to "Users", users_path,
                class: "block px-3 py-2 rounded-lg text-sm transition-colors #{controller_name == 'users' ? 'bg-surface-input text-content' : 'text-content-muted hover:bg-surface-input hover:text-content'}" %>
          <%= link_to "Data", data_management_path,
                class: "block px-3 py-2 rounded-lg text-sm transition-colors #{controller_name == 'data' ? 'bg-surface-input text-content' : 'text-content-muted hover:bg-surface-input hover:text-content'}" %>
        <% end %>

        <div class="flex-1"></div>
        <% if current_user %>
          <div class="border-t border-edge pt-3 mt-2 space-y-1">
            <%= link_to current_user.email, account_path,
                  class: "block px-3 py-1 text-xs text-content-muted truncate hover:text-content transition-colors" %>
            <% if current_user.otp_required_for_login? %>
              <%= link_to "Disable 2FA", disable_two_factor_path, data: { turbo_method: :post, turbo_confirm: "Disable two-factor authentication?" },
                    class: "block px-3 py-1.5 rounded-lg text-[0.8125rem] text-content-muted hover:bg-surface-input hover:text-content transition-colors" %>
            <% else %>
              <%= link_to "Enable 2FA", setup_two_factor_path,
                    class: "block px-3 py-1.5 rounded-lg text-[0.8125rem] text-content-muted hover:bg-surface-input hover:text-content transition-colors" %>
            <% end %>
            <%= link_to "Setup", setup_path,
                  class: "block px-3 py-1.5 rounded-lg text-[0.8125rem] text-content-muted hover:bg-surface-input hover:text-content transition-colors" %>
            <%= button_to "Sign Out", logout_path, method: :delete,
                  class: "block w-full text-left px-3 py-1.5 rounded-lg text-[0.8125rem] text-content-muted hover:bg-surface-input hover:text-content transition-colors bg-transparent border-none cursor-pointer" %>
          </div>
        <% end %>
        <button type="button" class="theme-switch flex items-center justify-center bg-transparent border-none cursor-pointer py-2" data-controller="theme-toggle" data-action="theme-toggle#toggle">
          <span class="theme-switch-track">
            <span class="theme-switch-icon theme-switch-sun">&#9788;</span>
            <span class="theme-switch-thumb" data-theme-toggle-target="thumb"></span>
            <span class="theme-switch-icon theme-switch-moon">&#9790;</span>
          </span>
        </button>
      </nav>

      <main class="p-8 max-w-[1400px] relative">
        <div class="main-watermark" style="background-image: url('<%= image_path('seneschal_bg.png') %>')"></div>
        <div class="relative z-10">
          <% flash.each do |type, message| %>
            <div class="<%= type == 'notice' ? 'bg-success/15 text-success border border-success/25' : 'bg-danger/15 text-danger border border-danger/25' %> px-4 py-3 rounded-lg mb-4 text-sm">
              <%= message %>
            </div>
          <% end %>
          <%= yield %>
        </div>
      </main>
    </div>
  </body>
</html>
