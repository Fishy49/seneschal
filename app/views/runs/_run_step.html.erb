<li class="flex items-start gap-2 py-2 border-b border-edge last:border-b-0" id="run_step_<%= run_step.id %>">
  <span class="w-7 h-7 rounded-full <%= run_step.status == "queued" ? "bg-info/15 text-info" : "bg-surface-input text-content-muted" %> text-[0.8125rem] font-semibold flex items-center justify-center shrink-0 mt-0.5"><%= run_step.position.to_i > 0 ? run_step.position : "&middot;".html_safe %></span>
  <div class="flex-1 min-w-0">
    <div class="flex items-center gap-2 flex-wrap">
      <span class="font-medium text-sm"><%= run_step.step.name %></span>
      <%= status_badge(run_step.status) %>
      <% if run_step.duration %>
        <span class="text-xs text-content-muted"><%= format_duration(run_step.duration) %></span>
      <% end %>
      <% if run_step.attempt > 1 %>
        <span class="text-xs text-content-muted">attempt <%= run_step.attempt %></span>
      <% end %>
    </div>
    <% if run_step.resolved_input_context.present? %>
      <div class="mt-1 inline-block" data-controller="content-modal" data-content-modal-title-value="Input Context — <%= run_step.step.name %>">
        <button type="button" data-action="content-modal#open"
                class="text-[0.8125rem] text-accent cursor-pointer bg-transparent border-none p-0 hover:text-accent-hover">input context</button>
        <template data-content-modal-target="source"><%= run_step.resolved_input_context %></template>
      </div>
    <% end %>
    <% if run_step.stream_log.present? %>
      <% entries = stream_log_entries(run_step.stream_log) %>
      <% cost_summary = stream_log_cost_summary(run_step.stream_log) %>
      <details class="mt-1" <%= "open" if run_step.status == "running" %>>
        <summary class="text-[0.8125rem] text-accent cursor-pointer select-none hover:text-accent-hover">
          activity log<% if cost_summary.present? %> <span class="text-content-muted">(<%= cost_summary %>)</span><% end %>
        </summary>
        <div class="mt-2 rounded-lg bg-surface border border-edge p-3 max-h-80 overflow-y-auto space-y-0.5" data-controller="autoscroll">
          <% entries.each do |entry| %>
            <% case entry[:type] %>
            <% when :tool_use %>
              <div class="flex items-start gap-1.5 text-xs font-mono">
                <span class="text-accent shrink-0">&#9656;</span>
                <span class="text-content-muted"><span class="text-content font-semibold"><%= entry[:tool] %></span> <%= tool_use_label(entry[:tool], entry[:input]) %></span>
              </div>
            <% when :text %>
              <div class="flex items-start gap-1.5 text-xs font-mono">
                <span class="text-content-muted shrink-0">&#9657;</span>
                <span class="text-content-muted"><%= entry[:text].truncate(300) %></span>
              </div>
            <% when :result %>
              <div class="flex items-start gap-1.5 text-xs font-mono mt-1 pt-1 border-t border-edge">
                <span class="text-success shrink-0">&#10003;</span>
                <span class="text-success">
                  Done
                  <% if entry[:turns] %>&middot; <%= entry[:turns] %> turns<% end %>
                  <% if entry[:cost] %>&middot; $<%= format("%.4f", entry[:cost]) %><% end %>
                  <% if entry[:duration_ms] %>&middot; <%= format_duration(entry[:duration_ms] / 1000.0) %><% end %>
                </span>
              </div>
            <% end %>
          <% end %>
          <% if run_step.status == "running" && entries.none? { |e| e[:type] == :result } %>
            <div class="flex items-center gap-1.5 text-xs font-mono text-content-muted animate-pulse">
              <span class="shrink-0">&#8943;</span>
              <span>working</span>
            </div>
          <% end %>
        </div>
      </details>
    <% end %>
    <% if run_step.output.present? || run_step.error_output.present? %>
      <div class="mt-1 flex items-center gap-3">
        <% if run_step.output.present? %>
          <div data-controller="content-modal" data-content-modal-title-value="Output — <%= run_step.step.name %>">
            <button type="button" data-action="content-modal#open"
                    class="text-[0.8125rem] text-content-muted cursor-pointer bg-transparent border-none p-0 hover:text-content">output</button>
            <template data-content-modal-target="source"><%= run_step.output %></template>
          </div>
        <% end %>
        <% if run_step.error_output.present? %>
          <% stderr_is_error = run_step.status == "failed" %>
          <div data-controller="content-modal" data-content-modal-title-value="<%= stderr_is_error ? 'Error' : 'Stderr' %> — <%= run_step.step.name %>">
            <button type="button" data-action="content-modal#open"
                    class="text-[0.8125rem] cursor-pointer bg-transparent border-none p-0 <%= stderr_is_error ? 'text-danger hover:text-danger/80' : 'text-content-muted hover:text-content' %>"><%= stderr_is_error ? "error" : "stderr" %></button>
            <template data-content-modal-target="source"><%= run_step.error_output %></template>
          </div>
        <% end %>
      </div>
    <% end %>
    <% if run.status.in?(%w[failed stopped]) && run_step.status == "failed" %>
      <div class="mt-2">
        <%= button_to "Retry from here",
              retry_from_run_path(run, step_id: run_step.step_id),
              class: "inline-flex items-center gap-1.5 px-2.5 py-1 bg-transparent border border-edge text-content-muted rounded-lg text-[0.8125rem] font-medium cursor-pointer hover:bg-surface-input hover:text-content transition-colors",
              data: { turbo_confirm: "Create a new run retrying from '#{run_step.step.name}'?" } %>
      </div>
    <% end %>
  </div>
</li>
