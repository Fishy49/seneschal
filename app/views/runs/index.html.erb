<h1 class="text-2xl font-semibold mb-4">Runs</h1>

<div class="bg-surface-card border border-edge rounded-lg p-4 mb-4">
  <%= form_with url: runs_path, method: :get, class: "flex items-center gap-3 flex-wrap", data: { turbo_frame: "_top" } do |f| %>
    <select name="project_id" onchange="this.form.requestSubmit()"
            class="px-3 py-2 bg-surface-input border border-edge rounded-lg text-content text-sm focus:outline-none focus:border-accent">
      <option value="">All Projects</option>
      <% @projects.each do |p| %>
        <option value="<%= p.id %>" <%= "selected" if params[:project_id].to_s == p.id.to_s %>><%= p.name %></option>
      <% end %>
    </select>
    <select name="status" onchange="this.form.requestSubmit()"
            class="px-3 py-2 bg-surface-input border border-edge rounded-lg text-content text-sm focus:outline-none focus:border-accent">
      <option value="">All Statuses</option>
      <% Run::STATUSES.each do |s| %>
        <option value="<%= s %>" <%= "selected" if params[:status] == s %>><%= s.capitalize %></option>
      <% end %>
    </select>
    <% if params[:project_id].present? || params[:status].present? %>
      <%= link_to "Clear", runs_path, class: "text-sm text-content-muted hover:text-content transition-colors" %>
    <% end %>
  <% end %>
</div>

<div class="bg-surface-card border border-edge rounded-lg p-5">
  <% if @runs.any? %>
    <table class="w-full border-collapse">
      <thead>
        <tr>
          <th class="text-left px-3 py-2 border-b border-edge text-xs font-semibold uppercase tracking-wide text-content-muted">Task</th>
          <th class="text-left px-3 py-2 border-b border-edge text-xs font-semibold uppercase tracking-wide text-content-muted">Project</th>
          <th class="text-left px-3 py-2 border-b border-edge text-xs font-semibold uppercase tracking-wide text-content-muted">Status</th>
          <th class="text-left px-3 py-2 border-b border-edge text-xs font-semibold uppercase tracking-wide text-content-muted">Duration</th>
          <th class="text-left px-3 py-2 border-b border-edge text-xs font-semibold uppercase tracking-wide text-content-muted">When</th>
        </tr>
      </thead>
      <tbody>
        <% @runs.each do |run| %>
          <tr>
            <td class="px-3 py-2 border-b border-edge">
              <% if run.pipeline_task %>
                <div><%= link_to run.pipeline_task.title, run_path(run) %></div>
              <% else %>
                <div><%= link_to "Run ##{run.id}", run_path(run) %></div>
              <% end %>
              <div class="text-xs text-content-muted"><%= run.workflow.name %></div>
            </td>
            <td class="px-3 py-2 border-b border-edge text-content-muted"><%= run.workflow.project.name %></td>
            <td class="px-3 py-2 border-b border-edge"><%= status_badge(run.status) %></td>
            <td class="px-3 py-2 border-b border-edge text-sm text-content-muted"><%= format_duration(run.duration) %></td>
            <td class="px-3 py-2 border-b border-edge text-sm text-content-muted"><%= time_ago_short(run.finished_at || run.created_at) %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p class="text-center py-12 text-content-muted">
      <% if params[:project_id].present? || params[:status].present? %>
        No runs match your filters. <%= link_to "Clear filters", runs_path %>
      <% else %>
        No runs yet
      <% end %>
    </p>
  <% end %>
</div>
