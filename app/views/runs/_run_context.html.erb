<div class="bg-surface-card border border-edge rounded-lg p-5 mb-4" id="run_context">
  <h2 class="text-lg font-semibold mb-3">Context</h2>
  <% if run.context.present? && run.context.any? %>
    <table class="w-full border-collapse">
      <% run.context.each do |key, value| %>
        <tr>
          <th class="text-left px-3 py-2 border-b border-edge text-xs font-semibold uppercase tracking-wide text-content-muted align-top"><%= key %></th>
          <td class="px-3 py-2 border-b border-edge text-sm">
            <% text = value.to_s %>
            <% if text.length > 200 %>
              <details>
                <summary class="cursor-pointer hover:text-accent"><code class="font-mono text-[0.8125rem]"><%= truncate(text, length: 200) %></code></summary>
                <div class="mt-2 whitespace-pre-wrap break-words max-h-96 overflow-y-auto"><code class="font-mono text-[0.8125rem]"><%= text %></code></div>
              </details>
            <% else %>
              <code class="font-mono text-[0.8125rem]"><%= text %></code>
            <% end %>
          </td>
        </tr>
      <% end %>
    </table>
  <% else %>
    <p class="text-sm text-content-muted">No context yet</p>
  <% end %>
</div>
