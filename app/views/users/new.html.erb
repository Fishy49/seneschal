<div class="max-w-md">
  <h1 class="text-2xl font-bold mb-6">New User</h1>
  <p class="text-sm text-content-muted mb-6">
    Create a user account. They'll receive an invite link to set their password.
  </p>

  <%= form_with model: @user, url: users_path, class: "space-y-4" do |f| %>
    <% if @user.errors.any? %>
      <div class="bg-danger/15 text-danger border border-danger/25 px-4 py-3 rounded-lg text-sm">
        <% @user.errors.full_messages.each do |msg| %>
          <p><%= msg %></p>
        <% end %>
      </div>
    <% end %>

    <div>
      <%= f.label :email, class: "block text-sm font-medium text-content-muted mb-1.5" %>
      <%= f.email_field :email, autofocus: true, required: true,
            class: "w-full px-3 py-2 bg-surface-input border border-edge rounded-lg text-content text-sm focus:outline-none focus:border-accent" %>
    </div>

    <div class="flex items-center gap-2">
      <%= f.check_box :admin, class: "rounded border-edge" %>
      <%= f.label :admin, "Admin", class: "text-sm text-content-muted" %>
    </div>

    <button type="submit"
            class="px-4 py-2.5 bg-accent text-white rounded-lg text-sm font-semibold cursor-pointer hover:bg-accent-hover transition-colors">
      Create User
    </button>

    <%= link_to "Cancel", users_path, class: "ml-2 text-sm text-content-muted hover:text-content" %>
  <% end %>
</div>
