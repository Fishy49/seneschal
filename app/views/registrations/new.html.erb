<h2 class="text-xl font-semibold text-center mb-6">Create Account</h2>

<%= form_with model: @user, url: register_path, class: "space-y-4" do |f| %>
  <% if @user.errors.any? %>
    <div class="bg-danger/15 text-danger border border-danger/25 px-4 py-3 rounded-lg text-sm">
      <% @user.errors.full_messages.each do |msg| %>
        <p><%= msg %></p>
      <% end %>
    </div>
  <% end %>

  <div>
    <%= f.label :email, class: "block text-sm font-medium text-content-muted mb-1.5" %>
    <%= f.email_field :email, autofocus: true, required: true,
          class: "w-full px-3 py-2 bg-surface-input border border-edge rounded-lg text-content text-sm focus:outline-none focus:border-accent" %>
  </div>

  <div>
    <%= f.label :password, class: "block text-sm font-medium text-content-muted mb-1.5" %>
    <%= f.password_field :password, required: true,
          class: "w-full px-3 py-2 bg-surface-input border border-edge rounded-lg text-content text-sm focus:outline-none focus:border-accent" %>
  </div>

  <div>
    <%= f.label :password_confirmation, "Confirm Password", class: "block text-sm font-medium text-content-muted mb-1.5" %>
    <%= f.password_field :password_confirmation, required: true,
          class: "w-full px-3 py-2 bg-surface-input border border-edge rounded-lg text-content text-sm focus:outline-none focus:border-accent" %>
  </div>

  <button type="submit"
          class="w-full px-4 py-2.5 bg-accent text-white rounded-lg text-sm font-semibold cursor-pointer hover:bg-accent-hover transition-colors">
    Create Account
  </button>
<% end %>

<p class="text-center text-sm text-content-muted mt-6">
  Already have an account? <%= link_to "Sign in", login_path, class: "text-accent hover:text-accent-hover font-medium" %>
</p>
