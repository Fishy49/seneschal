<span id="repo_status"
      <% if project.repo_status == "cloning" %>
        data-controller="poll-status"
        data-poll-status-url-value="<%= repo_status_project_path(project) %>"
      <% end %>>
  <% case project.repo_status %>
  <% when "not_cloned" %>
    <% if project.local_path.present? && !File.directory?(File.dirname(project.local_path)) %>
      <span class="text-xs text-warning" title="Parent directory does not exist: <%= File.dirname(project.local_path) %>">Parent path missing</span>
      <%= link_to "Edit Path", edit_project_path(project),
            class: "ml-2 inline-flex items-center gap-1.5 px-2.5 py-1 bg-transparent border border-edge text-content-muted rounded-lg text-[0.8125rem] font-medium cursor-pointer hover:bg-surface-input hover:text-content transition-colors" %>
    <% else %>
      <%= button_to "Clone Repository", clone_project_path(project),
            class: "inline-flex items-center gap-1.5 px-4 py-2 bg-accent text-white rounded-lg text-sm font-medium cursor-pointer hover:bg-accent-hover transition-colors",
            data: { turbo_confirm: "Clone #{project.repo_url}?" } %>
    <% end %>
  <% when "cloning" %>
    <span class="text-xs text-content-muted">Cloning...</span>
  <% when "ready" %>
    <span class="text-xs text-content-muted">Repo cloned</span>
  <% when "error" %>
    <%= status_badge("failed") %>
    <%= button_to "Retry Clone", clone_project_path(project),
          class: "inline-flex items-center gap-1.5 px-2.5 py-1 bg-transparent border border-edge text-content-muted rounded-lg text-[0.8125rem] font-medium cursor-pointer hover:bg-surface-input hover:text-content transition-colors" %>
  <% end %>
</span>
