<div class="flex items-center justify-between mb-4">
  <h1 class="text-2xl font-semibold">Projects</h1>
  <%= link_to "New Project", new_project_path, class: "inline-flex items-center gap-1.5 px-4 py-2 bg-accent text-white rounded-lg text-sm font-medium cursor-pointer hover:bg-accent-hover transition-colors" %>
</div>

<% if @projects.any? %>
  <% @projects.each do |project| %>
    <div class="bg-surface-card border border-edge rounded-lg p-5 mb-4 group">
      <div class="flex items-center justify-between">
        <div class="flex-1">
          <h3 class="text-base font-semibold">
            <%= link_to project.name, project_path(project), class: "text-content hover:text-accent transition-colors" %>
          </h3>
          <p class="text-sm text-content-muted"><%= project.repo_url %></p>
          <% if project.description.present? %>
            <p class="text-sm text-content-muted mt-1"><%= project.description %></p>
          <% end %>
          <div class="text-xs text-content-muted mt-2">
            <%= pluralize(project.workflows.count, "workflow") %> &middot; <%= pluralize(project.pipeline_tasks.count, "task") %>
          </div>
        </div>
        <div class="flex flex-col items-end gap-2">
          <span class="text-xs text-content-muted"><%= project.repo_status == "ready" ? "Repo cloned" : project.repo_status.titleize %></span>
          <div class="flex items-center gap-2">
            <%= link_to "New Task", new_pipeline_task_path(project_id: project.id), class: "inline-flex items-center gap-1.5 px-2.5 py-1 bg-accent text-white rounded-lg text-[0.8125rem] font-medium cursor-pointer hover:bg-accent-hover transition-colors" %>
            <%= link_to "View", project_path(project), class: "inline-flex items-center gap-1.5 px-2.5 py-1 bg-transparent border border-edge text-content-muted rounded-lg text-[0.8125rem] font-medium cursor-pointer hover:bg-surface-input hover:text-content transition-colors" %>
          </div>
        </div>
      </div>
    </div>
  <% end %>
<% else %>
  <div class="bg-surface-card border border-edge rounded-lg p-12 text-center text-content-muted">
    <p>No projects yet.</p>
    <p class="mt-2"><%= link_to "Create your first project", new_project_path %></p>
  </div>
<% end %>
