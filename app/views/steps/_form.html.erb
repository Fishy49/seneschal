<% skills = Skill.for_project(@project).includes(:project, :project_group).order(:name) %>
<% claude_cfg = step.step_type.in?(%w[skill prompt]) ? (step.config || {}) : {} %>
<% ci = step.step_type == "ci_check" ? (step.config || {}) : {} %>
<% ctx_fetch = step.step_type == "context_fetch" ? (step.config || {}) : {} %>
<% pr_cfg = step.step_type == "pr" ? (step.config || {}) : {} %>
<% templates = StepTemplate.ordered %>
<% schema_mode = step.step_type.in?(%w[skill prompt]) && claude_cfg["json_schema_id"].present? %>
<% schema_output_var = schema_mode ? step.produces.first : "" %>
<%= form_with model: [@project, @workflow, step],
      data: { controller: "step-form",
              step_form_skills_value: skills.map { |s| [s.id, s.body] }.to_h.to_json,
              step_form_templates_value: templates.map { |t| [t.id, t.template_data] }.to_h.to_json } do |f| %>
  <% if step.errors.any? %>
    <div class="bg-danger/15 text-danger border border-danger/25 px-4 py-3 rounded-lg mb-4 text-sm">
      <% step.errors.full_messages.each do |msg| %>
        <p><%= msg %></p>
      <% end %>
    </div>
  <% end %>

  <% if step.new_record? && templates.any? %>
    <div class="mb-6 pb-4 border-b border-edge flex items-center justify-between">
      <button type="button" data-action="template-panel#open"
              class="inline-flex items-center gap-1.5 px-3 py-2 bg-surface-input border border-edge rounded-lg text-sm text-content-muted hover:text-content hover:bg-edge transition-colors cursor-pointer">
        Choose Template
        <span class="text-xs opacity-60">(<%= templates.size %>)</span>
      </button>
      <%= link_to "Manage Templates", step_templates_path,
            class: "text-xs text-content-muted hover:text-accent transition-colors" %>
    </div>
  <% end %>

  <div class="mb-4">
    <%= f.label :name, class: "block text-sm font-medium text-content-muted mb-1.5" %>
    <%= f.text_field :name, placeholder: "ingest",
          class: "w-full px-3 py-2 bg-surface-input border border-edge rounded-lg text-content text-sm focus:outline-none focus:border-accent" %>
  </div>

  <div class="mb-4">
    <%= f.label :position, class: "block text-sm font-medium text-content-muted mb-1.5" %>
    <%= f.number_field :position, min: 1,
          class: "w-full px-3 py-2 bg-surface-input border border-edge rounded-lg text-content text-sm focus:outline-none focus:border-accent" %>
  </div>

  <div class="mb-4">
    <%= f.label :step_type, "Type", class: "block text-sm font-medium text-content-muted mb-1.5" %>
    <%= f.select :step_type,
          [["Skill", "skill"], ["Prompt", "prompt"], ["Script", "script"], ["Command", "command"], ["CI Check", "ci_check"], ["Context Fetch", "context_fetch"], ["Open PR", "pr"]],
          {}, class: "w-full px-3 py-2 bg-surface-input border border-edge rounded-lg text-content text-sm focus:outline-none focus:border-accent",
          data: { step_form_target: "typeSelect", action: "step-form#toggle" } %>
  </div>

  <%# === Skill fields (skill picker only) === %>
  <div data-step-form-target="skillFields" style="<%= 'display:none' unless step.step_type == 'skill' %>">
    <div class="mb-4">
      <%= f.label :skill_id, "Skill", class: "block text-sm font-medium text-content-muted mb-1.5" %>
      <%= f.hidden_field :skill_id, data: { step_form_target: "skillSelect" } %>
      <div class="flex items-center gap-3">
        <button type="button" data-action="skill-panel#open"
                class="inline-flex items-center gap-1.5 px-3 py-2 bg-surface-input border border-edge rounded-lg text-sm text-content-muted hover:text-content hover:bg-edge transition-colors cursor-pointer">
          Select Skill
        </button>
        <span data-step-form-target="skillName" class="text-sm text-content">
          <% if step.skill %>
            <%= step.skill.display_name %>
          <% else %>
            <span class="text-content-muted">No skill selected</span>
          <% end %>
        </span>
      </div>
    </div>

    <div data-step-form-target="skillPreview" style="<%= 'display:none' unless step.skill %>" class="mb-4">
      <div class="flex items-center justify-between">
        <label class="text-sm text-content-muted">Prompt Preview</label>
        <button type="button" class="inline-flex items-center gap-1.5 px-2.5 py-1 bg-transparent border border-edge text-content-muted rounded-lg text-[0.8125rem] font-medium cursor-pointer hover:bg-surface-input hover:text-content transition-colors" data-action="step-form#togglePreview">
          <span data-step-form-target="previewToggleText">Show</span>
        </button>
      </div>
      <div data-step-form-target="previewBody" style="display:none" class="mt-2">
        <div class="code-preview" data-step-form-target="previewContent"></div>
      </div>
    </div>
  </div>

  <%# === Body field (script / command / prompt) === %>
  <div data-step-form-target="bodyFields" style="<%= 'display:none' unless step.step_type.in?(%w[script command prompt]) %>">
    <div class="mb-4">
      <% body_label = case step.step_type when "script" then "Script" when "command" then "Command" when "prompt" then "Prompt" else "Body" end %>
      <%= f.label :body, body_label, data: { step_form_target: "bodyLabel" }, class: "block text-sm font-medium text-content-muted mb-1.5" %>
      <%= f.text_area :body, rows: 8,
            placeholder: "git checkout main && git pull",
            class: "w-full px-3 py-2 bg-surface-input border border-edge rounded-lg text-content text-sm font-mono focus:outline-none focus:border-accent resize-y" %>
    </div>
  </div>

  <%# === Claude config (skill / prompt) === %>
  <div data-step-form-target="claudeConfigFields" style="<%= 'display:none' unless step.step_type.in?(%w[skill prompt]) %>">
    <div class="grid grid-cols-3 gap-4">
      <div class="mb-4">
        <label for="skill_model" class="block text-sm font-medium text-content-muted mb-1.5">Model</label>
        <select name="skill_model" id="skill_model" class="w-full px-3 py-2 bg-surface-input border border-edge rounded-lg text-content text-sm focus:outline-none focus:border-accent">
          <option value="">Default</option>
          <option value="claude-opus-4-7" <%= "selected" if claude_cfg["model"] == "claude-opus-4-7" %>>Opus 4.7</option>
          <option value="claude-sonnet-4-6" <%= "selected" if claude_cfg["model"] == "claude-sonnet-4-6" %>>Sonnet 4.6</option>
          <option value="claude-haiku-4-5-20251001" <%= "selected" if claude_cfg["model"] == "claude-haiku-4-5-20251001" %>>Haiku 4.5</option>
        </select>
      </div>
      <div class="mb-4">
        <label for="skill_effort" class="block text-sm font-medium text-content-muted mb-1.5">Effort</label>
        <select name="skill_effort" id="skill_effort" class="w-full px-3 py-2 bg-surface-input border border-edge rounded-lg text-content text-sm focus:outline-none focus:border-accent">
          <option value="low" <%= "selected" if claude_cfg["effort"] == "low" %>>Low</option>
          <option value="medium" <%= "selected" if claude_cfg["effort"].blank? || claude_cfg["effort"] == "medium" %>>Medium</option>
          <option value="high" <%= "selected" if claude_cfg["effort"] == "high" %>>High</option>
          <option value="xhigh" <%= "selected" if claude_cfg["effort"] == "xhigh" %>>XHigh</option>
          <option value="max" <%= "selected" if claude_cfg["effort"] == "max" %>>Max</option>
        </select>
      </div>
      <div class="mb-4">
        <label for="skill_max_turns" class="block text-sm font-medium text-content-muted mb-1.5">Max Turns</label>
        <input type="number" name="skill_max_turns" id="skill_max_turns"
               value="<%= claude_cfg["max_turns"] %>" min="1" placeholder="Default"
               class="w-full px-3 py-2 bg-surface-input border border-edge rounded-lg text-content text-sm focus:outline-none focus:border-accent">
      </div>
    </div>

    <div class="mb-4">
      <label for="skill_allowed_tools" class="block text-sm font-medium text-content-muted mb-1.5">Allowed Tools</label>
      <input type="text" name="skill_allowed_tools" id="skill_allowed_tools"
             value="<%= claude_cfg["allowed_tools"] %>"
             placeholder="Leave blank to use global default"
             class="w-full px-3 py-2 bg-surface-input border border-edge rounded-lg text-content text-sm font-mono focus:outline-none focus:border-accent">
      <p class="text-sm text-content-muted mt-2">Comma-separated list of Claude CLI tools this step can use. Supports patterns like <code class="text-xs bg-surface-input px-1 py-0.5 rounded">Bash(git *)</code>. Leave blank for the global default.</p>
    </div>

    <%# Output schema picker. When the selected skill carries a default
        schema + output variable, the picker collapses to a compact "Using
        skill default" badge so the common case is one-line. Click "Override"
        to expand the full picker. %>
    <% skill_default_schema = step.skill&.default_json_schema %>
    <% skill_default_var    = step.skill&.default_output_variable.to_s %>
    <% picker_selected_id   = claude_cfg["json_schema_id"].to_i %>
    <% using_skill_default  = skill_default_schema && (claude_cfg["json_schema_id"].blank? || picker_selected_id == skill_default_schema.id) %>
    <div class="mb-4" data-controller="step-schema-picker" data-step-schema-picker-overridden-value="<%= using_skill_default ? 'false' : 'true' %>">
      <%# mode marker: "inherit" → controller leaves config["json_schema_id"] absent
          so Step#inherit_skill_defaults can fill it from skill.default_json_schema.
          "override" → controller writes whatever the picker has (id or nil) so the
          user's explicit choice (including None) sticks. %>
      <input type="hidden" name="schema_picker_mode"
             value="<%= using_skill_default ? 'inherit' : 'override' %>"
             data-step-schema-picker-target="modeInput">
      <label class="block text-sm font-medium text-content-muted mb-1.5">Output Schema</label>

      <% if skill_default_schema %>
        <div data-step-schema-picker-target="badge" style="<%= 'display:none' if !using_skill_default %>"
             class="flex items-center justify-between gap-3 px-3 py-2 bg-surface-input border border-edge rounded-lg">
          <div class="flex items-center gap-2 min-w-0">
            <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-semibold bg-accent/15 text-accent uppercase tracking-wide shrink-0">From skill</span>
            <span class="text-sm font-mono text-content truncate"><%= skill_default_schema.name %></span>
            <% if skill_default_var.present? %>
              <span class="text-xs text-content-muted">→</span>
              <span class="text-xs font-mono text-content-muted truncate"><%= skill_default_var %></span>
            <% end %>
          </div>
          <button type="button" data-action="step-schema-picker#override"
                  class="text-xs text-accent hover:underline shrink-0">Override</button>
        </div>
      <% end %>

      <div data-step-schema-picker-target="picker" style="<%= 'display:none' if using_skill_default && skill_default_schema %>">
        <select name="json_schema_id" id="json_schema_id"
                data-step-form-target="schemaSelect" data-action="step-form#schemaChanged"
                class="w-full px-3 py-2 bg-surface-input border border-edge rounded-lg text-content text-sm focus:outline-none focus:border-accent">
          <option value="">None</option>
          <% JsonSchema.order(:name).each do |s| %>
            <option value="<%= s.id %>" <%= "selected" if claude_cfg["json_schema_id"].to_i == s.id %>><%= s.name %></option>
          <% end %>
        </select>
        <% if skill_default_schema %>
          <button type="button" data-action="step-schema-picker#restoreDefault"
                  class="text-xs text-content-muted hover:text-accent mt-1">↩ Use skill default (<%= skill_default_schema.name %>)</button>
        <% end %>
        <p class="text-xs text-content-muted mt-1">When set, the step's only output is a single variable holding JSON that conforms to this schema.</p>
      </div>
    </div>

    <% other_projects  = Project.where.not(id: @project.id).order(:name) %>
    <% selected_ids    = (claude_cfg["context_projects"] || []).map(&:to_i) %>
    <div class="mb-4">
      <label for="skill_context_projects" class="block text-sm font-medium text-content-muted mb-1.5">Context Projects</label>
      <% if other_projects.any? %>
        <select name="skill_context_projects[]" id="skill_context_projects" multiple size="<%= [other_projects.size, 6].min %>"
                class="w-full px-3 py-2 bg-surface-input border border-edge rounded-lg text-content text-sm focus:outline-none focus:border-accent">
          <% other_projects.each do |p| %>
            <option value="<%= p.id %>" <%= "selected" if selected_ids.include?(p.id) %>>
              <%= p.name %><%= " (not cloned)" unless p.repo_ready? %>
            </option>
          <% end %>
        </select>
        <p class="text-sm text-content-muted mt-2">Each selected project's local directory is passed to Claude via <code class="text-xs bg-surface-input px-1 py-0.5 rounded">--add-dir</code> and noted in the prompt. Hold Cmd/Ctrl to select multiple. Projects that aren't cloned are silently skipped at run time.</p>
      <% else %>
        <p class="text-sm text-content-muted">No other projects in Seneschal to attach.</p>
      <% end %>
    </div>
  </div>

  <%# === CI Check fields === %>
  <div data-step-form-target="ciCheckFields" style="<%= 'display:none' unless step.step_type == 'ci_check' %>">
    <div class="grid grid-cols-2 gap-4">
      <div class="mb-4">
        <label for="ci_mode" class="block text-sm font-medium text-content-muted mb-1.5">Mode</label>
        <select name="ci_mode" id="ci_mode" data-step-form-target="ciMode" data-action="step-form#ciModeChanged"
                class="w-full px-3 py-2 bg-surface-input border border-edge rounded-lg text-content text-sm focus:outline-none focus:border-accent">
          <option value="pr" <%= "selected" unless ci["mode"] == "workflow" %>>PR Checks</option>
          <option value="workflow" <%= "selected" if ci["mode"] == "workflow" %>>Workflow Run</option>
        </select>
      </div>
      <div class="mb-4">
        <label for="ci_poll_interval" class="block text-sm font-medium text-content-muted mb-1.5">Poll Interval (seconds)</label>
        <input type="number" name="ci_poll_interval" id="ci_poll_interval"
               value="<%= ci["poll_interval"] || 30 %>" min="10"
               class="w-full px-3 py-2 bg-surface-input border border-edge rounded-lg text-content text-sm focus:outline-none focus:border-accent">
      </div>
    </div>

    <div data-step-form-target="ciLogFields" style="<%= 'display:none' if ci["mode"] == "workflow" %>" class="grid grid-cols-2 gap-4">
      <div class="mb-4">
        <label for="ci_max_log_chars" class="block text-sm font-medium text-content-muted mb-1.5">Max Failure Log Size (characters)</label>
        <input type="number" name="ci_max_log_chars" id="ci_max_log_chars"
               value="<%= ci["max_log_chars"] || 10_000 %>" min="1000" step="1000"
               class="w-full px-3 py-2 bg-surface-input border border-edge rounded-lg text-content text-sm focus:outline-none focus:border-accent">
      </div>
      <div class="mb-4">
        <label for="ci_log_from" class="block text-sm font-medium text-content-muted mb-1.5">Read Logs From</label>
        <select name="ci_log_from" id="ci_log_from"
                class="w-full px-3 py-2 bg-surface-input border border-edge rounded-lg text-content text-sm focus:outline-none focus:border-accent">
          <option value="end" <%= "selected" unless ci["log_from"] == "beginning" %>>End (error summaries)</option>
          <option value="beginning" <%= "selected" if ci["log_from"] == "beginning" %>>Beginning</option>
        </select>
      </div>
    </div>

    <div data-step-form-target="ciPrFields" style="<%= 'display:none' if ci["mode"] == "workflow" %>">
      <div class="mb-4">
        <label for="ci_pr" class="block text-sm font-medium text-content-muted mb-1.5">PR Number (variable)</label>
        <input type="text" name="ci_pr" id="ci_pr"
               value="<%= ci["pr"] || "${pr_number}" %>"
               placeholder="${pr_number}"
               class="w-full px-3 py-2 bg-surface-input border border-edge rounded-lg text-content text-sm focus:outline-none focus:border-accent">
      </div>
    </div>

    <div data-step-form-target="ciWorkflowFields" style="<%= 'display:none' unless ci["mode"] == "workflow" %>">
      <div class="mb-4">
        <label for="ci_workflow" class="block text-sm font-medium text-content-muted mb-1.5">Workflow File</label>
        <input type="text" name="ci_workflow" id="ci_workflow"
               value="<%= ci["workflow"] %>"
               placeholder="ci.yml"
               class="w-full px-3 py-2 bg-surface-input border border-edge rounded-lg text-content text-sm focus:outline-none focus:border-accent">
      </div>
      <div class="mb-4">
        <label for="ci_ref" class="block text-sm font-medium text-content-muted mb-1.5">Branch/Ref (variable)</label>
        <input type="text" name="ci_ref" id="ci_ref"
               value="<%= ci["ref"] || "${branch}" %>"
               placeholder="${branch}"
               class="w-full px-3 py-2 bg-surface-input border border-edge rounded-lg text-content text-sm focus:outline-none focus:border-accent">
      </div>
      <div class="mb-4">
        <label class="flex items-center gap-2 cursor-pointer text-sm text-content-muted">
          <input type="checkbox" name="ci_trigger" value="1" <%= "checked" if ci["trigger"] %>>
          Trigger workflow run (otherwise just watch for results)
        </label>
      </div>
    </div>
  </div>

  <%# === Context Fetch fields === %>
  <% fetch_method = ctx_fetch["method"].presence || "url" %>
  <% fetch_path = ctx_fetch["path"].to_s %>
  <% fetch_path_is_json = fetch_path.downcase.end_with?(".json") %>
  <div data-step-form-target="contextFetchFields" style="<%= 'display:none' unless step.step_type == 'context_fetch' %>">
    <div class="mb-4">
      <label for="fetch_method" class="block text-sm font-medium text-content-muted mb-1.5">Method</label>
      <select name="fetch_method" id="fetch_method"
              data-step-form-target="fetchMethod" data-action="step-form#fetchMethodChanged"
              class="w-full px-3 py-2 bg-surface-input border border-edge rounded-lg text-content text-sm focus:outline-none focus:border-accent">
        <option value="url" <%= "selected" if fetch_method == "url" %>>URL</option>
        <option value="project_file" <%= "selected" if fetch_method == "project_file" %>>Project File</option>
      </select>
      <p class="text-sm text-content-muted mt-2">How to fetch context. URLs support GitHub auto-resolve; Project File reads from the project's working tree.</p>
    </div>

    <div data-step-form-target="fetchUrlFields" style="<%= 'display:none' unless fetch_method == 'url' %>" class="mb-4">
      <label for="fetch_url" class="block text-sm font-medium text-content-muted mb-1.5">URL</label>
      <input type="text" name="fetch_url" id="fetch_url"
             value="<%= ctx_fetch["url"] %>"
             placeholder="https://github.com/owner/repo or https://example.com/llms.txt"
             class="w-full px-3 py-2 bg-surface-input border border-edge rounded-lg text-content text-sm font-mono focus:outline-none focus:border-accent">
      <p class="text-sm text-content-muted mt-2">Supports <code class="text-xs bg-surface-input px-1 py-0.5 rounded">${variable}</code> interpolation. GitHub repo URLs fetch the README; blob URLs fetch the file.</p>
    </div>

    <div data-step-form-target="fetchProjectFileFields" style="<%= 'display:none' unless fetch_method == 'project_file' %>" class="mb-4">
      <label class="block text-sm font-medium text-content-muted mb-1.5">Project File</label>
      <div class="flex items-center gap-3">
        <button type="button" data-action="file-panel#open"
                class="inline-flex items-center gap-1.5 px-3 py-2 bg-surface-input border border-edge rounded-lg text-sm text-content-muted hover:text-content hover:bg-edge transition-colors cursor-pointer">
          Select File
        </button>
        <code data-step-form-target="fetchPathDisplay" class="text-xs text-content font-mono break-all">
          <% if fetch_path.present? %><%= fetch_path %><% else %><span class="text-content-muted">No file selected</span><% end %>
        </code>
      </div>
      <input type="hidden" name="fetch_path" data-step-form-target="fetchPath" value="<%= fetch_path %>">
      <p class="text-sm text-content-muted mt-2">Reads the file from the project's working tree at run time. Requires a generated code map for picking files.</p>

      <div data-step-form-target="fetchSchemaFields" style="<%= 'display:none' unless fetch_path_is_json %>" class="mt-3">
        <label for="fetch_json_schema_id" class="block text-sm font-medium text-content-muted mb-1.5">JSON Schema (optional)</label>
        <select name="fetch_json_schema_id" id="fetch_json_schema_id"
                class="w-full px-3 py-2 bg-surface-input border border-edge rounded-lg text-content text-sm focus:outline-none focus:border-accent">
          <option value="">None</option>
          <% JsonSchema.order(:name).each do |s| %>
            <option value="<%= s.id %>" <%= "selected" if ctx_fetch["json_schema_id"].to_i == s.id %>><%= s.name %></option>
          <% end %>
        </select>
        <p class="text-xs text-content-muted mt-1">When set, downstream steps can reference sub-paths of this file's JSON (e.g. <code class="bg-surface-input px-1 rounded">config.feature_flags</code>).</p>
      </div>
    </div>

    <div class="mb-4">
      <label for="fetch_context_key" class="block text-sm font-medium text-content-muted mb-1.5">Context Key</label>
      <input type="text" name="fetch_context_key" id="fetch_context_key"
             value="<%= ctx_fetch["context_key"] %>"
             placeholder="e.g. project_readme"
             class="w-full px-3 py-2 bg-surface-input border border-edge rounded-lg text-content text-sm focus:outline-none focus:border-accent">
      <p class="text-sm text-content-muted mt-2">Store the fetched content in run context under this key for use by later steps.</p>
    </div>
  </div>

  <%# === PR step fields === %>
  <div data-step-form-target="prFields" style="<%= 'display:none' unless step.step_type == 'pr' %>">
    <div class="mb-4">
      <label for="pr_title" class="block text-sm font-medium text-content-muted mb-1.5">PR Title</label>
      <input type="text" name="pr_title" id="pr_title"
             value="<%= pr_cfg["title"] %>"
             placeholder="e.g. feat: ${task_title}"
             class="w-full px-3 py-2 bg-surface-input border border-edge rounded-lg text-content text-sm focus:outline-none focus:border-accent">
      <p class="text-xs text-content-muted mt-1">Supports <code class="bg-surface-input px-1 rounded">${variable}</code> interpolation from run context.</p>
    </div>

    <div class="mb-4">
      <label for="pr_body" class="block text-sm font-medium text-content-muted mb-1.5">PR Body</label>
      <textarea name="pr_body" id="pr_body" rows="6"
                placeholder="## Summary&#10;&#10;${task_body}"
                class="w-full px-3 py-2 bg-surface-input border border-edge rounded-lg text-content text-sm font-mono focus:outline-none focus:border-accent resize-y"><%= pr_cfg["body"] %></textarea>
      <p class="text-xs text-content-muted mt-1">Markdown supported. Same <code class="bg-surface-input px-1 rounded">${variable}</code> interpolation as the title.</p>
    </div>

    <div class="grid grid-cols-2 gap-4">
      <div class="mb-4">
        <label for="pr_base" class="block text-sm font-medium text-content-muted mb-1.5">Base Branch</label>
        <input type="text" name="pr_base" id="pr_base"
               value="<%= pr_cfg["base"] || "main" %>"
               placeholder="main"
               class="w-full px-3 py-2 bg-surface-input border border-edge rounded-lg text-content text-sm focus:outline-none focus:border-accent">
      </div>
      <div class="mb-4">
        <label for="pr_branch" class="block text-sm font-medium text-content-muted mb-1.5">Head Branch (optional)</label>
        <input type="text" name="pr_branch" id="pr_branch"
               value="<%= pr_cfg["branch"] %>"
               placeholder="auto-detect (current branch)"
               class="w-full px-3 py-2 bg-surface-input border border-edge rounded-lg text-content text-sm focus:outline-none focus:border-accent">
      </div>
    </div>

    <div class="mb-4">
      <label class="flex items-center gap-2 cursor-pointer text-sm text-content-muted">
        <input type="checkbox" name="pr_draft" value="1" <%= "checked" if pr_cfg.fetch("draft", true) %> class="accent-accent">
        Open as draft
      </label>
      <p class="text-xs text-content-muted mt-1">Recommended — leaves the PR draft until CI passes and a human marks it ready.</p>
    </div>

    <div class="mb-4">
      <label class="flex items-center gap-2 cursor-pointer text-sm text-danger">
        <input type="checkbox" name="pr_clean" value="1" <%= "checked" if pr_cfg["clean"] %> class="accent-danger">
        Clean re-create (destructive)
      </label>
      <p class="text-xs text-content-muted mt-1">
        On re-runs: close any existing open PRs for this branch (with an audit
        comment), <code>git push --delete</code> the remote branch, then push
        local fresh and open a new PR. Use when the branch's previous history
        is no longer valid — e.g. after a forced rebase or a botched run.
        Default off; the idempotent reuse path is the safer default.
      </p>
    </div>

    <div class="mb-4">
      <label for="pr_reviewers" class="block text-sm font-medium text-content-muted mb-1.5">Reviewers (optional)</label>
      <input type="text" name="pr_reviewers" id="pr_reviewers"
             value="<%= Array(pr_cfg["reviewers"]).join(", ") %>"
             placeholder="alice, bob, my-org/backend-team"
             class="w-full px-3 py-2 bg-surface-input border border-edge rounded-lg text-content text-sm focus:outline-none focus:border-accent">
      <p class="text-xs text-content-muted mt-1">Comma-separated GitHub handles or org/team slugs.</p>
    </div>

    <div class="grid grid-cols-2 gap-4">
      <div class="mb-4">
        <label for="pr_labels" class="block text-sm font-medium text-content-muted mb-1.5">Labels (optional)</label>
        <input type="text" name="pr_labels" id="pr_labels"
               value="<%= Array(pr_cfg["labels"]).join(", ") %>"
               placeholder="feature, needs-review"
               class="w-full px-3 py-2 bg-surface-input border border-edge rounded-lg text-content text-sm focus:outline-none focus:border-accent">
      </div>
      <div class="mb-4">
        <label for="pr_assignees" class="block text-sm font-medium text-content-muted mb-1.5">Assignees (optional)</label>
        <input type="text" name="pr_assignees" id="pr_assignees"
               value="<%= Array(pr_cfg["assignees"]).join(", ") %>"
               placeholder="alice, bob"
               class="w-full px-3 py-2 bg-surface-input border border-edge rounded-lg text-content text-sm focus:outline-none focus:border-accent">
      </div>
    </div>

    <p class="text-xs text-content-muted mb-4">PR steps automatically produce <code class="bg-surface-input px-1 rounded">pr_number</code>, <code class="bg-surface-input px-1 rounded">pr_url</code>, and <code class="bg-surface-input px-1 rounded">branch_name</code> for downstream steps. If a PR already exists for the head branch, it is reused (idempotent).</p>
  </div>

  <%# === Pipeline variables (consumes checkboxes) === %>
  <% available_vars = Step.available_variables_for(@workflow, step.position.to_i) %>

  <%# === Pipeline: Produces / Consumes === %>
  <div class="grid grid-cols-2 gap-4">
    <div data-step-form-target="producesMultiFields" style="<%= 'display:none' if schema_mode %>">
      <label class="block text-sm font-medium text-content-muted mb-1.5">Produces</label>
      <div data-controller="produces-input"
           data-step-form-target="producesInputWrapper"
           data-produces-input-suggestions-url-value="<%= produces_suggestions_project_workflow_steps_path(@project, @workflow) %>"
           data-produces-input-initial-value="<%= schema_mode ? "" : step.produces.join(",") %>">
        <ul data-produces-input-target="tagList" class="flex flex-wrap gap-1 mb-1.5 min-h-[1.5rem]"></ul>
        <div class="flex gap-1.5">
          <input type="text" data-produces-input-target="newInput"
                 list="produces_input_suggestions"
                 data-action="keydown->produces-input#keydown input->produces-input#input"
                 placeholder="pr_number"
                 class="flex-1 px-3 py-1.5 bg-surface-input border border-edge rounded-lg text-content text-sm font-mono focus:outline-none focus:border-accent">
          <button type="button" data-action="produces-input#add"
                  class="px-3 py-1.5 bg-surface-input border border-edge text-content-muted rounded-lg text-sm hover:bg-edge hover:text-content transition-colors cursor-pointer">Add</button>
        </div>
        <datalist id="produces_input_suggestions" data-produces-input-target="datalist"></datalist>
        <input type="hidden" name="produces" data-produces-input-target="hiddenInput" value="<%= schema_mode ? "" : step.produces.join(",") %>">
      </div>
      <p class="text-xs text-content-muted mt-1">Variable names this step outputs. For AI steps, Claude is instructed to produce these in a <code class="bg-surface-input px-1 rounded">```output</code> block. For scripts, use <code class="bg-surface-input px-1 rounded">::set-output name=value</code>.</p>
    </div>

    <div data-step-form-target="schemaOutputFields" style="<%= 'display:none' unless schema_mode %>">
      <label for="schema_output_variable" class="block text-sm font-medium text-content-muted mb-1.5">Output Variable</label>
      <input type="text" name="schema_output_variable" id="schema_output_variable"
             value="<%= schema_output_var %>"
             data-step-form-target="schemaOutputInput"
             placeholder="result"
             class="w-full px-3 py-1.5 bg-surface-input border border-edge rounded-lg text-content text-sm font-mono focus:outline-none focus:border-accent">
      <p class="text-xs text-content-muted mt-1">Claude emits the JSON conforming to the selected schema as the value of this single output variable.</p>
    </div>

    <div class="mb-4">
      <label class="block text-sm font-medium text-content-muted mb-1.5">Consumes</label>
      <% if available_vars.any? %>
        <div class="max-h-44 overflow-y-auto bg-surface-input border border-edge rounded-lg px-3 py-2">
          <div class="grid grid-cols-[auto_auto_1fr_auto] gap-x-3 gap-y-1 items-center text-xs">
            <span class="text-[0.6875rem] font-semibold uppercase tracking-wide text-content-muted">Inject</span>
            <span class="text-[0.6875rem] font-semibold uppercase tracking-wide text-content-muted">Query</span>
            <span class="text-[0.6875rem] font-semibold uppercase tracking-wide text-content-muted">Variable</span>
            <span class="text-[0.6875rem] font-semibold uppercase tracking-wide text-content-muted">Source</span>
            <% available_vars.each do |var| %>
              <input type="checkbox" name="consumes[]" value="<%= var["name"] %>"
                     <%= "checked" if step.consumes.include?(var["name"]) %>
                     class="accent-accent justify-self-center">
              <% if var["queryable"] %>
                <input type="checkbox" name="queries[]" value="<%= var["name"] %>"
                       <%= "checked" if step.queries.include?(var["name"]) %>
                       class="accent-accent justify-self-center">
              <% else %>
                <span class="text-content-muted/30 justify-self-center">—</span>
              <% end %>
              <code class="text-xs"><%= var["name"] %></code>
              <span class="text-xs text-content-muted"><%= var["source"] %></span>
            <% end %>
          </div>
        </div>
      <% else %>
        <p class="text-xs text-content-muted py-2">No variables available at this position. Global variables are always accessible.</p>
      <% end %>
      <p class="text-xs text-content-muted mt-1"><strong>Inject</strong> loads the variable's value into the prompt up front (good for small values). <strong>Query</strong> exposes the variable through a <code class="bg-surface-input px-1 rounded">seneschal-context</code> CLI tool the step can call with jq expressions to pull only what it needs (good for large JSON-schema'd structures). Dotted entries like <code class="bg-surface-input px-1 rounded">review.summary</code> inject a sub-path of an upstream JSON value.</p>
    </div>
  </div>

  <%# === Input Context (all types) === %>
  <div class="mb-4">
    <%= f.label :input_context, "Additional Context", class: "block text-sm font-medium text-content-muted mb-1.5" %>
    <%= f.text_area :input_context, rows: 4,
          placeholder: "Optional instructions injected into this step. Supports ${variable} interpolation.\nFor retries, use ${previous_failure} to reference the prior failure output.",
          class: "w-full px-3 py-2 bg-surface-input border border-edge rounded-lg text-content text-sm font-mono focus:outline-none focus:border-accent resize-y" %>
    <p class="text-sm text-content-muted mt-2">Appended to skill prompts or available as $INPUT_CONTEXT for scripts</p>
  </div>

  <div class="grid grid-cols-2 gap-4">
    <div class="mb-4">
      <%= f.label :max_retries, "Max Retries", class: "block text-sm font-medium text-content-muted mb-1.5" %>
      <%= f.number_field :max_retries, min: 0,
            class: "w-full px-3 py-2 bg-surface-input border border-edge rounded-lg text-content text-sm focus:outline-none focus:border-accent" %>
    </div>

    <div class="mb-4">
      <%= f.label :timeout, "Timeout (seconds)", class: "block text-sm font-medium text-content-muted mb-1.5" %>
      <%= f.number_field :timeout, min: 1,
            class: "w-full px-3 py-2 bg-surface-input border border-edge rounded-lg text-content text-sm focus:outline-none focus:border-accent" %>
    </div>
  </div>

  <%# === Manual Approval === %>
  <div class="mb-4 pt-4 border-t border-edge">
    <label class="flex items-center gap-2 cursor-pointer text-sm text-content-muted">
      <%= f.check_box :manual_approval, class: "accent-accent" %>
      Manual Approval
    </label>
    <p class="text-xs text-content-muted mt-1">When this step finishes, the run pauses in <em>Awaiting Approval</em> until an operator approves or rejects it.</p>
  </div>

  <%# === On Fail Action === %>
  <% on_fail = step.config&.dig("on_fail_action") || {} %>
  <div class="mb-4" data-step-form-target="onFailFields">
    <label for="on_fail_type" class="block text-sm font-medium text-content-muted mb-1.5">On Fail</label>
    <div class="grid grid-cols-[1fr_auto] gap-4">
      <select name="on_fail_type" id="on_fail_type"
              data-step-form-target="onFailType" data-action="step-form#onFailChanged"
              class="w-full px-3 py-2 bg-surface-input border border-edge rounded-lg text-content text-sm focus:outline-none focus:border-accent">
        <option value="">None</option>
        <option value="reopen_previous" <%= "selected" if on_fail["type"] == "reopen_previous" %>>Re-Open Previous Step</option>
        <option value="skill" <%= "selected" if on_fail["type"] == "skill" %>>Run Skill</option>
        <option value="script" <%= "selected" if on_fail["type"] == "script" %>>Run Script</option>
        <option value="command" <%= "selected" if on_fail["type"] == "command" %>>Run Command</option>
      </select>
      <div>
        <input type="number" name="on_fail_max_rounds" id="on_fail_max_rounds"
               value="<%= on_fail["max_rounds"] || 3 %>" min="1" placeholder="Rounds"
               style="<%= 'display:none' unless on_fail["type"].present? %>"
               data-step-form-target="onFailMaxRounds"
               class="w-24 px-3 py-2 bg-surface-input border border-edge rounded-lg text-content text-sm focus:outline-none focus:border-accent">
      </div>
    </div>

    <div data-step-form-target="onFailSkillFields" style="<%= 'display:none' unless on_fail["type"] == "skill" %>" class="mt-2">
      <label for="on_fail_skill_id" class="block text-sm font-medium text-content-muted mb-1.5">Recovery Skill</label>
      <select name="on_fail_skill_id" id="on_fail_skill_id"
              class="w-full px-3 py-2 bg-surface-input border border-edge rounded-lg text-content text-sm focus:outline-none focus:border-accent">
        <option value="">Select a skill...</option>
        <% Skill.for_project(@project).includes(:project, :project_group).order(:name).each do |s| %>
          <option value="<%= s.id %>" <%= "selected" if on_fail["skill_id"].to_s == s.id.to_s %>><%= s.display_name %></option>
        <% end %>
      </select>
      <p class="text-xs text-content-muted mt-1">The failure output and step name are automatically prepended to the skill's prompt — no need to reference <code class="bg-surface-input px-1 rounded">${previous_failure}</code> manually.</p>
    </div>

    <div data-step-form-target="onFailReopenFields" style="<%= 'display:none' unless on_fail["type"] == "reopen_previous" %>" class="mt-2">
      <label for="on_fail_instructions" class="block text-sm font-medium text-content-muted mb-1.5">Additional Instructions</label>
      <textarea name="on_fail_instructions" id="on_fail_instructions" rows="3"
                placeholder="Optional extra guidance for the resumed session"
                class="w-full px-3 py-2 bg-surface-input border border-edge rounded-lg text-content text-sm font-mono focus:outline-none focus:border-accent resize-y"><%= on_fail["instructions"] %></textarea>
      <p class="text-xs text-content-muted mt-1">Resumes the previous skill step's Claude session with the full output of this step and these instructions.</p>
    </div>

    <div data-step-form-target="onFailBodyFields" style="<%= 'display:none' unless on_fail["type"].in?(%w[script command]) %>" class="mt-2">
      <label for="on_fail_body" class="block text-sm font-medium text-content-muted mb-1.5">Recovery <%= on_fail["type"]&.capitalize || "Script" %></label>
      <textarea name="on_fail_body" id="on_fail_body" rows="4"
                placeholder="Script or command to run on failure. Has access to $PREVIOUS_FAILURE and $PREVIOUS_FAILURE_STEP."
                class="w-full px-3 py-2 bg-surface-input border border-edge rounded-lg text-content text-sm font-mono focus:outline-none focus:border-accent resize-y"><%= on_fail["body"] %></textarea>
    </div>
    <p class="text-xs text-content-muted mt-1">When this step fails, run a recovery action then re-execute. Repeats up to max rounds.</p>
  </div>

  <div class="mb-4 pt-4 border-t border-edge">
    <label class="flex items-center gap-2 cursor-pointer text-sm text-content-muted">
      <input type="checkbox" name="save_as_template" value="1" class="accent-accent"
             data-step-form-target="saveTemplateCheck" data-action="step-form#toggleSaveTemplate">
      Save as Template
    </label>
    <div data-step-form-target="saveTemplateFields" style="display:none" class="mt-2">
      <input type="text" name="template_name" placeholder="Template name"
             class="w-full px-3 py-2 bg-surface-input border border-edge rounded-lg text-content text-sm focus:outline-none focus:border-accent">
    </div>
  </div>

  <div class="flex gap-2">
    <%= f.submit class: "inline-flex items-center gap-1.5 px-4 py-2 bg-accent text-white rounded-lg text-sm font-medium cursor-pointer hover:bg-accent-hover transition-colors" %>
    <%= link_to "Cancel", project_workflow_path(@project, @workflow), class: "inline-flex items-center gap-1.5 px-4 py-2 bg-transparent border border-edge text-content-muted rounded-lg text-sm font-medium hover:bg-surface-input hover:text-content transition-colors" %>
  </div>
<% end %>
