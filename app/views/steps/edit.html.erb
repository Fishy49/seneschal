<%= render "shared/project_bar", project: @project, workflow: @workflow %>
<h1 class="text-2xl font-semibold mb-4">Edit Step: <%= @step.name %></h1>
<% skills = Skill.for_project(@project).includes(:project, :project_group).order(:name) %>
<div data-controller="skill-panel file-panel">
  <div class="bg-surface-card border border-edge rounded-lg p-5">
    <%= render "form", step: @step %>
  </div>
  <%= render "steps/skill_panel", skills: skills %>
  <%= render "steps/file_panel", project: @project %>
</div>
