<div class="flex items-center justify-between mb-4">
  <div>
    <p class="text-sm text-content-muted"><%= link_to "Project Groups", project_groups_path %></p>
    <h1 class="text-2xl font-semibold"><%= @group.name %></h1>
  </div>
  <div class="flex items-center gap-2">
    <%= link_to "Edit", edit_project_group_path(@group), class: "inline-flex items-center gap-1.5 px-2.5 py-1 bg-transparent border border-edge text-content-muted rounded-lg text-[0.8125rem] font-medium cursor-pointer hover:bg-surface-input hover:text-content transition-colors" %>
  </div>
</div>

<% if @group.description.present? %>
  <p class="text-content-muted mb-4"><%= @group.description %></p>
<% end %>

<div class="bg-surface-card border border-edge rounded-lg p-5 mb-4">
  <h2 class="text-lg font-semibold mb-3">Projects</h2>
  <% if @projects.any? %>
    <ul class="space-y-1">
      <% @projects.each do |project| %>
        <li class="text-sm"><%= link_to project.name, project_path(project) %></li>
      <% end %>
    </ul>
  <% else %>
    <p class="text-sm text-content-muted">No projects in this group.</p>
  <% end %>
</div>

<div class="bg-surface-card border border-edge rounded-lg p-5 mb-4">
  <h2 class="text-lg font-semibold mb-3">Skills</h2>
  <% if @skills.any? %>
    <table class="w-full border-collapse">
      <thead>
        <tr>
          <th class="text-left px-3 py-2 border-b border-edge text-xs font-semibold uppercase tracking-wide text-content-muted">Name</th>
          <th class="text-left px-3 py-2 border-b border-edge text-xs font-semibold uppercase tracking-wide text-content-muted">Description</th>
          <th class="text-left px-3 py-2 border-b border-edge text-xs font-semibold uppercase tracking-wide text-content-muted">Used by</th>
        </tr>
      </thead>
      <tbody>
        <% @skills.each do |skill| %>
          <tr>
            <td class="px-3 py-2 border-b border-edge"><%= link_to skill.name, skill_path(skill) %></td>
            <td class="px-3 py-2 border-b border-edge text-sm text-content-muted"><%= truncate(skill.description, length: 80) %></td>
            <td class="px-3 py-2 border-b border-edge text-sm text-content-muted"><%= pluralize(skill.steps.count, "step") %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p class="text-sm text-content-muted">No skills yet.</p>
  <% end %>
</div>
