<div class="flex items-center justify-between mb-4">
  <div>
    <p class="text-sm text-content-muted"><%= link_to "Project Groups", project_groups_path %></p>
    <h1 class="text-2xl font-semibold"><%= @group.name %></h1>
  </div>
  <div class="flex items-center gap-2">
    <%= link_to "Edit", edit_project_group_path(@group), class: "inline-flex items-center gap-1.5 px-2.5 py-1 bg-transparent border border-edge text-content-muted rounded-lg text-[0.8125rem] font-medium cursor-pointer hover:bg-surface-input hover:text-content transition-colors" %>
  </div>
</div>

<% if @group.description.present? %>
  <p class="text-content-muted mb-4"><%= @group.description %></p>
<% end %>

<div class="bg-surface-card border border-edge rounded-lg p-5 mb-4">
  <h2 class="text-lg font-semibold mb-3">Projects</h2>
  <% if @projects.any? %>
    <ul class="space-y-1">
      <% @projects.each do |project| %>
        <li class="text-sm"><%= link_to project.name, project_path(project) %></li>
      <% end %>
    </ul>
  <% else %>
    <p class="text-sm text-content-muted">No projects in this group.</p>
  <% end %>
</div>

