# See https://docs.docker.com/engine/reference/builder/#dockerignore-file for more about ignoring files.

# Ignore git directory.
/.git/
/.gitignore

# Ignore bundler config.
/.bundle

# Ignore all environment files.
/.env*

# Ignore all default key files.
/config/master.key
/config/credentials/*.key

# Ignore all logfiles and tempfiles.
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

# Ignore pidfiles, but keep the directory.
/tmp/pids/*
!/tmp/pids/.keep

# Ignore storage (uploaded files in development and any SQLite databases).
/storage/*
!/storage/.keep
/tmp/storage/*
!/tmp/storage/.keep

# Ignore assets.
/node_modules/
/app/assets/builds/*
!/app/assets/builds/.keep
/public/assets

# Ignore CI service files.
/.github

# Ignore host-built Python venv for the SDK runner. It's architecture-
# specific (darwin/linux x86/arm), gets rebuilt inside the image, and
# would otherwise clash with uv's "already exists" check.
/lib/sdk_runner/.venv

# Ignore docker-compose-mounted dirs so they don't fatten the build
# context. The image creates these inside the container itself.
/repos/*
!/repos/.keep
/skills/*
!/skills/.keep
/worktrees/*
!/worktrees/.keep

# Ignore development files
/.devcontainer

# Ignore Docker-related files
/.dockerignore
/Dockerfile*
