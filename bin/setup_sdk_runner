#!/usr/bin/env bash
#
# bin/setup_sdk_runner — provision the Python venv that backs the
# Runners::ClaudeSDK runner.
#
# Idempotent: re-running upgrades dependencies in place. Uses `uv` if
# available (faster, lock-aware); falls back to stock `python3 -m venv`
# + pip otherwise. The venv lives at lib/sdk_runner/.venv/ and is
# auto-discovered by Runners::ClaudeSDK#python_bin.

set -euo pipefail

cd "$(dirname "$0")/.."
RUNNER_DIR="lib/sdk_runner"
VENV_DIR="${RUNNER_DIR}/.venv"

echo "==> Provisioning Python sidecar venv at ${VENV_DIR}"

if command -v uv >/dev/null 2>&1; then
  echo "    using uv (detected at $(command -v uv))"
  uv venv --python ">=3.10" "${VENV_DIR}"
  uv pip install --python "${VENV_DIR}/bin/python" --upgrade -e "${RUNNER_DIR}"
else
  echo "    uv not found; using python3 + pip"
  if ! command -v python3 >/dev/null 2>&1; then
    echo "ERROR: neither uv nor python3 is on PATH. Install one and retry." >&2
    exit 1
  fi

  python3 -m venv "${VENV_DIR}"
  "${VENV_DIR}/bin/pip" install --quiet --upgrade pip
  "${VENV_DIR}/bin/pip" install --upgrade -e "${RUNNER_DIR}"
fi

echo
echo "==> Verifying the install"
"${VENV_DIR}/bin/python" -c "import claude_agent_sdk; print(f'    claude-agent-sdk {claude_agent_sdk.__version__ if hasattr(claude_agent_sdk, \"__version__\") else \"installed\"}')"

echo
echo "Done. To route a Step through the SDK runner instead of the CLI:"
echo "  step.update!(config: step.config.merge(\"runner\" => \"claude_sdk\"))"
echo
echo "Or flip the global default:"
echo "  Setting[\"default_runner\"] = \"claude_sdk\""
