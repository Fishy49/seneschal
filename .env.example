# Copy to .env and fill in. docker-compose reads this file automatically.

# --- Required ---

# Rails session signing key. Generate once and keep stable across restarts,
# otherwise every login cookie is invalidated on container restart.
#   openssl rand -hex 64
SECRET_KEY_BASE=

# Claude API key — preferred for headless containers. Get one at
# https://console.anthropic.com/settings/keys
# Claude Pro/Max users can skip this and mount ~/.claude instead
# (see the OPTIONAL bind in docker-compose.yml).
ANTHROPIC_API_KEY=

# --- Optional ---

# GitHub auth token used by the `pr` step type. Either set this OR mount
# your host's ~/.config/gh as a volume. Needs `repo` scope plus
# `read:project` if you wire up cron / branch-watch triggers.
# https://github.com/settings/tokens
GH_TOKEN=

# Host port to publish the web UI on. Default 3000.
SENESCHAL_PORT=3000
